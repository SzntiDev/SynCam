{
  "name": "syncam-desktop",
  "version": "1.0.0",
  "description": "SynCam - Use your phone as a webcam",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.syncam.pro",
    "productName": "SynCam Desktop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "perMachine": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "obs-websocket-js": "^5.0.8",
    "serve-static": "^1.15.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1"
  },
  "keywords": [
    "camera",
    "webcam",
    "streaming",
    "droidcam"
  ],
  "author": "SynCam",
  "license": "MIT"
}
